@model CarPaintingStudio.Models.Service
@{
    ViewData["Title"] = "Изтриване на услуга";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="fas fa-trash me-2"></i>Изтриване на услуга</h5>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    Сигурни ли сте, че искате да изтриете тази услуга? Действието е необратимо.
                </div>

                <table class="table table-bordered">
                    <tr>
                        <th class="table-light" style="width:40%">Услуга</th>
                        <td><strong>@Model.Name</strong></td>
                    </tr>
                    <tr>
                        <th class="table-light">Цена</th>
                        <td>@Model.Price.ToString("F2") лв.</td>
                    </tr>
                    <tr>
                        <th class="table-light">Продължителност</th>
                        <td>@Model.DurationDays дни</td>
                    </tr>
                    <tr>
                        <th class="table-light">Записвания</th>
                        <td>
                            @if (Model.Appointments.Any())
                            {
                                <span class="badge bg-danger">@Model.Appointments.Count() — не може да се изтрие!</span>
                            }
                            else
                            {
                                <span class="badge bg-success">0 — може да се изтрие</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <th class="table-light">Статус</th>
                        <td>@(Model.IsActive ? "Активна" : "Неактивна")</td>
                    </tr>
                </table>

                @if (Model.Appointments.Any())
                {
                    <div class="alert alert-danger">
                        <i class="fas fa-ban me-2"></i>
                        Не можете да изтриете тази услуга, защото има <strong>@Model.Appointments.Count()</strong> свързани записвания.
                    </div>
                    <a asp-area="Admin" asp-controller="Services" asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-2"></i>Назад
                    </a>
                }
                else
                {
                    <form asp-area="Admin" asp-controller="Services" asp-action="Delete"
                          asp-route-id="@Model.Id" method="post">
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash me-2"></i>Изтрий
                            </button>
                            <a asp-area="Admin" asp-controller="Services" asp-action="Index"
                               class="btn btn-outline-secondary">
                                <i class="fas fa-times me-2"></i>Откажи
                            </a>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
</div>
