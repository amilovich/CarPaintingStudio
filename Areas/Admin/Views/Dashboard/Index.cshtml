@model IEnumerable<CarPaintingStudio.Models.Appointment>
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@* Статистически карти *@
<div class="row g-3 mb-4">
    <div class="col-md-4 col-lg-2">
        <div class="card stat-card blue shadow-sm h-100">
            <div class="card-body text-center py-3">
                <i class="fas fa-tools fa-2x text-primary mb-2"></i>
                <h3 class="fw-bold mb-0">@ViewBag.TotalServices</h3>
                <small class="text-muted">Общо услуги</small>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="card stat-card green shadow-sm h-100">
            <div class="card-body text-center py-3">
                <i class="fas fa-check-circle fa-2x text-success mb-2"></i>
                <h3 class="fw-bold mb-0">@ViewBag.ActiveServices</h3>
                <small class="text-muted">Активни услуги</small>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="card stat-card orange shadow-sm h-100">
            <div class="card-body text-center py-3">
                <i class="fas fa-calendar-check fa-2x text-warning mb-2"></i>
                <h3 class="fw-bold mb-0">@ViewBag.TotalAppointments</h3>
                <small class="text-muted">Записвания</small>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="card stat-card red shadow-sm h-100">
            <div class="card-body text-center py-3">
                <i class="fas fa-clock fa-2x text-danger mb-2"></i>
                <h3 class="fw-bold mb-0">@ViewBag.PendingAppointments</h3>
                <small class="text-muted">Чакащи</small>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="card stat-card purple shadow-sm h-100">
            <div class="card-body text-center py-3">
                <i class="fas fa-users fa-2x text-purple mb-2" style="color:#9b59b6"></i>
                <h3 class="fw-bold mb-0">@ViewBag.TotalEmployees</h3>
                <small class="text-muted">Служители</small>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="card stat-card teal shadow-sm h-100">
            <div class="card-body text-center py-3">
                <i class="fas fa-images fa-2x mb-2" style="color:#1abc9c"></i>
                <h3 class="fw-bold mb-0">@ViewBag.TotalGalleryItems</h3>
                <small class="text-muted">Галерия</small>
            </div>
        </div>
    </div>
</div>

@* Бързи действия *@
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-white fw-bold">
                <i class="fas fa-bolt me-2 text-warning"></i>Бързи действия
            </div>
            <div class="card-body d-flex flex-wrap gap-2">
                <a asp-area="Admin" asp-controller="Services" asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-plus me-1"></i>Нова услуга
                </a>
                <a asp-area="Admin" asp-controller="Appointments" asp-action="Index" class="btn btn-outline-warning">
                    <i class="fas fa-calendar-check me-1"></i>Записвания
                </a>
                <a asp-area="" asp-controller="Gallery" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-images me-1"></i>Галерия
                </a>
            </div>
        </div>
    </div>
</div>

@* Последни записвания *@
<div class="card shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <span class="fw-bold"><i class="fas fa-calendar-alt me-2 text-primary"></i>Последни записвания</span>
        <a asp-area="Admin" asp-controller="Appointments" asp-action="Index" class="btn btn-sm btn-outline-primary">
            Всички <i class="fas fa-arrow-right ms-1"></i>
        </a>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <p class="text-muted text-center py-4">Няма записвания.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Клиент</th>
                            <th>Автомобил</th>
                            <th>Услуга</th>
                            <th>Дата</th>
                            <th>Статус</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in Model)
                        {
                            <tr>
                                <td>@a.CustomerName</td>
                                <td>@a.CarBrand @a.CarModel</td>
                                <td>@a.Service?.Name</td>
                                <td>@a.AppointmentDate.ToString("dd.MM.yyyy")</td>
                                <td>
                                    @{
                                        var badgeClass = a.Status switch
                                        {
                                            CarPaintingStudio.Models.AppointmentStatus.Pending    => "bg-warning text-dark",
                                            CarPaintingStudio.Models.AppointmentStatus.Confirmed  => "bg-info text-dark",
                                            CarPaintingStudio.Models.AppointmentStatus.InProgress => "bg-primary",
                                            CarPaintingStudio.Models.AppointmentStatus.Completed  => "bg-success",
                                            CarPaintingStudio.Models.AppointmentStatus.Cancelled  => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @badgeClass">@a.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
