@model CarPaintingStudio.Controllers.ErrorViewModel
@{
    ViewData["Title"] = "Грешка";
}

<div class="container">
    <div class="row justify-content-center mt-5">
        <div class="col-md-8">
            <div class="card shadow-lg">
                <div class="card-body text-center py-5">
                    <i class="fas fa-exclamation-triangle fa-5x text-danger mb-4"></i>
                    <h1 class="text-danger mb-3">Упс! Нещо се обърка</h1>
                    <p class="lead text-muted mb-4">
                        Възникна неочаквана грешка при обработката на вашата заявка.
                    </p>

                    @if (Model?.ShowRequestId == true)
                    {
                        <div class="alert alert-secondary">
                            <strong><i class="fas fa-info-circle"></i> Request ID:</strong>
                            <code>@Model.RequestId</code>
                        </div>
                    }

                    <hr class="my-4">

                    <div class="d-flex justify-content-center gap-3">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
                            <i class="fas fa-home"></i> Към началната страница
                        </a>
                        <button onclick="window.history.back()" class="btn btn-secondary btn-lg">
                            <i class="fas fa-arrow-left"></i> Назад
                        </button>
                    </div>

                    <div class="mt-5">
                        <p class="text-muted">
                            <i class="fas fa-question-circle"></i>
                            Ако проблемът продължава, моля свържете се с нас на
                            <a href="mailto:info@carpaint.bg">info@carpaint.bg</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fa-exclamation-triangle {
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0%, 100% {
            opacity: 1;
        }
        50% {
            opacity: 0.6;
        }
    }
</style>
