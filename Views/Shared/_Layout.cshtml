<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CarPainting Studio</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-car"></i> CarPainting Studio
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home"></i> Начало
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Services" asp-action="Index">
                                <i class="fas fa-tools"></i> Услуги
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Appointments" asp-action="Create">
                                <i class="fas fa-calendar-plus"></i> Запиши час
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Gallery" asp-action="Index">
                                <i class="fas fa-images"></i> Галерия
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="About">
                                <i class="fas fa-info-circle"></i> За нас
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Appointments" asp-action="Index">
                                <i class="fas fa-list"></i> Записвания
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-dark text-white mt-5">
        <div class="container py-4">
            <div class="row">
                <div class="col-md-3">
                    <h5><i class="fas fa-car"></i> CarPainting Studio</h5>
                    <p>Професионално боядисване на автомобили с внимание към детайла.</p>
                    <div class="social-links mt-3">
                        <a href="#" class="text-white me-3" title="Facebook">
                            <i class="fab fa-facebook fa-2x"></i>
                        </a>
                        <a href="#" class="text-white me-3" title="Instagram">
                            <i class="fab fa-instagram fa-2x"></i>
                        </a>
                        <a href="#" class="text-white me-3" title="YouTube">
                            <i class="fab fa-youtube fa-2x"></i>
                        </a>
                        <a href="#" class="text-white" title="LinkedIn">
                            <i class="fab fa-linkedin fa-2x"></i>
                        </a>
                    </div>
                </div>
                <div class="col-md-3">
                    <h5><i class="fas fa-phone"></i> Контакти</h5>
                    <p class="mb-2">
                        <i class="fas fa-phone-alt"></i> 
                        <a href="tel:0888123456" class="text-white text-decoration-none">0888 123 456</a>
                    </p>
                    <p class="mb-2">
                        <i class="fas fa-envelope"></i> 
                        <a href="mailto:info@carpaint.bg" class="text-white text-decoration-none">info@carpaint.bg</a>
                    </p>
                    <p class="mb-0">
                        <i class="fas fa-map-marker-alt"></i> 
                        гр. София, бул. Цариградско шосе 100
                    </p>
                </div>
                <div class="col-md-3">
                    <h5><i class="fas fa-clock"></i> Работно време</h5>
                    <p class="mb-1">
                        <i class="fas fa-calendar-week"></i> Понеделник - Петък:
                    </p>
                    <p class="ms-4 mb-2">08:00 - 18:00</p>
                    <p class="mb-1">
                        <i class="fas fa-calendar-day"></i> Събота:
                    </p>
                    <p class="ms-4 mb-2">09:00 - 14:00</p>
                    <p class="mb-1">
                        <i class="fas fa-calendar-times"></i> Неделя:
                    </p>
                    <p class="ms-4 mb-0">Почивен ден</p>
                </div>
                <div class="col-md-3">
                    <h5><i class="fas fa-envelope-open-text"></i> Новини</h5>
                    <p>Абонирайте се за нашите новини и оферти!</p>
                    <form id="newsletterForm" class="newsletter-form">
                        <div class="input-group mb-2">
                            <input type="email" class="form-control" placeholder="Ваш имейл" required>
                            <button class="btn btn-primary" type="submit">
                                <i class="fas fa-paper-plane"></i>
                            </button>
                        </div>
                        <small class="text-muted">Няма да споделяме вашия имейл</small>
                    </form>
                </div>
            </div>
            <hr class="bg-white my-4" />
            <div class="row">
                <div class="col-md-6">
                    <p class="mb-0">
                        &copy; 2025 CarPainting Studio. Всички права запазени.
                    </p>
                </div>
                <div class="col-md-6 text-md-end">
                    <a asp-controller="Home" asp-action="Index" class="text-white text-decoration-none me-3">Начало</a>
                    <a asp-controller="Services" asp-action="Index" class="text-white text-decoration-none me-3">Услуги</a>
                    <a asp-controller="Gallery" asp-action="Index" class="text-white text-decoration-none me-3">Галерия</a>
                    <a asp-controller="Home" asp-action="About" class="text-white text-decoration-none">За нас</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
