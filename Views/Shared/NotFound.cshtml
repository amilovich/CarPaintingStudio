@{
    ViewData["Title"] = "Страницата не е намерена";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">

            @* Голямо 404 *@
            <div style="font-size: 8rem; font-weight: 900; line-height: 1;
                        background: linear-gradient(135deg, #e74c3c, #c0392b);
                        -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                404
            </div>

            <i class="fas fa-car-crash fa-4x text-muted mb-4 d-block"></i>

            <h2 class="fw-bold mb-3">Упс! Страницата не е намерена</h2>
            <p class="text-muted lead mb-4">
                Изглежда тази страница е изчезнала като боя след дъжд.<br />
                Може би е преместена, изтрита или адресът е изписан грешно.
            </p>

            @* Полезни линкове *@
            <div class="card border-0 bg-light p-4 mb-4 text-start d-inline-block">
                <p class="fw-semibold mb-2 text-center">Може да ви помогнат тези линкове:</p>
                <ul class="list-unstyled mb-0">
                    <li class="mb-2">
                        <i class="fas fa-home text-primary me-2"></i>
                        <a asp-controller="Home" asp-action="Index" class="text-decoration-none">Начална страница</a>
                    </li>
                    <li class="mb-2">
                        <i class="fas fa-tools text-primary me-2"></i>
                        <a asp-controller="Services" asp-action="Index" class="text-decoration-none">Нашите услуги</a>
                    </li>
                    <li class="mb-2">
                        <i class="fas fa-calendar-plus text-primary me-2"></i>
                        <a asp-controller="Appointments" asp-action="Create" class="text-decoration-none">Запиши час</a>
                    </li>
                    <li>
                        <i class="fas fa-images text-primary me-2"></i>
                        <a asp-controller="Gallery" asp-action="Index" class="text-decoration-none">Галерия</a>
                    </li>
                </ul>
            </div>

            <div class="d-flex gap-3 justify-content-center">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-4">
                    <i class="fas fa-home me-2"></i>Начало
                </a>
                <button onclick="window.history.back()" class="btn btn-outline-secondary btn-lg px-4">
                    <i class="fas fa-arrow-left me-2"></i>Назад
                </button>
            </div>

        </div>
    </div>
</div>

<style>
    body { background-color: #f8f9fa; }
</style>
