@{
    ViewData["Title"] = "Страницата не е намерена";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">

            @* 404 число *@
            <div style="font-size: 8rem; font-weight: 900; line-height: 1;
                        background: linear-gradient(135deg, #e74c3c, #c0392b);
                        -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                404
            </div>

            <i class="fas fa-car-crash fa-4x text-muted mb-4 d-block"></i>

            <h2 class="fw-bold mb-3">Упс! Страницата не е намерена</h2>
            <p class="text-muted lead mb-2">
                Изглежда тази страница е изчезнала като боя след дъжд.
            </p>
            <p class="text-muted mb-4">
                Може би е преместена, изтрита или адресът е изписан грешно.
            </p>

            @* Бързо търсене *@
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Може да ви помогнат тези линкове:</h5>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <a asp-controller="Home" asp-action="Index"
                               class="btn btn-outline-secondary w-100 text-start">
                                <i class="fas fa-home text-primary me-2"></i>Начална страница
                            </a>
                        </div>
                        <div class="col-md-6">
                            <a asp-controller="Services" asp-action="Index"
                               class="btn btn-outline-secondary w-100 text-start">
                                <i class="fas fa-tools text-primary me-2"></i>Нашите услуги
                            </a>
                        </div>
                        <div class="col-md-6">
                            <a asp-controller="Appointments" asp-action="Create"
                               class="btn btn-outline-secondary w-100 text-start">
                                <i class="fas fa-calendar-plus text-primary me-2"></i>Запиши час
                            </a>
                        </div>
                        <div class="col-md-6">
                            <a asp-controller="Gallery" asp-action="Index"
                               class="btn btn-outline-secondary w-100 text-start">
                                <i class="fas fa-images text-primary me-2"></i>Галерия
                            </a>
                        </div>
                        <div class="col-md-6">
                            <a asp-controller="Reviews" asp-action="Index"
                               class="btn btn-outline-secondary w-100 text-start">
                                <i class="fas fa-star text-warning me-2"></i>Отзиви
                            </a>
                        </div>
                        <div class="col-md-6">
                            <a asp-controller="Home" asp-action="About"
                               class="btn btn-outline-secondary w-100 text-start">
                                <i class="fas fa-info-circle text-primary me-2"></i>За нас
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-4">
                    <i class="fas fa-home me-2"></i>Начало
                </a>
                <a asp-controller="Appointments" asp-action="Create"
                   class="btn btn-warning btn-lg px-4">
                    <i class="fas fa-calendar-plus me-2"></i>Запиши час
                </a>
                <button onclick="window.history.back()" class="btn btn-outline-secondary btn-lg px-4">
                    <i class="fas fa-arrow-left me-2"></i>Назад
                </button>
            </div>

            @* Контакти *@
            <p class="text-muted small mt-4">
                Нужна ви е помощ?
                <a href="tel:0888123456" class="text-decoration-none">0888 123 456</a>
                &nbsp;|&nbsp;
                <a href="mailto:info@carpaint.bg" class="text-decoration-none">info@carpaint.bg</a>
            </p>

        </div>
    </div>
</div>

<style>
    body { background-color: #f8f9fa; }
</style>
