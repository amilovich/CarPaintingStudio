@model CarPaintingStudio.ViewModels.PaginatedList<CarPaintingStudio.Models.Review>
@{
    ViewData["Title"] = "Отзиви";
    double avg   = ViewBag.AverageRating;
    int total    = ViewBag.TotalReviews;
    var filter   = ViewBag.Filter as CarPaintingStudio.ViewModels.ReviewFilterViewModel
                   ?? new CarPaintingStudio.ViewModels.ReviewFilterViewModel();
}

<div class="container mt-4">

    @* Заглавие *@
    <div class="row align-items-center mb-4">
        <div class="col-md-8">
            <h2 class="fw-bold">
                <i class="fas fa-star text-warning me-2"></i>Отзиви от клиенти
            </h2>
            <p class="text-muted lead">Вижте какво казват нашите клиенти за работата ни.</p>
        </div>
        <div class="col-md-4 text-md-end">
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <a asp-action="Create" class="btn btn-primary btn-lg">
                    <i class="fas fa-pen me-2"></i>Напиши отзив
                </a>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login"
                   asp-route-returnUrl="/Reviews/Create"
                   class="btn btn-outline-primary btn-lg">
                    <i class="fas fa-sign-in-alt me-2"></i>Влез за да напишеш отзив
                </a>
            }
        </div>
    </div>

    @* Обща статистика *@
    @if (total > 0)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-3 text-center border-end">
                        <div class="display-3 fw-bold text-warning">@avg</div>
                        <div class="mb-1">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="fas fa-star @(i <= Math.Round(avg) ? "text-warning" : "text-muted")"></i>
                            }
                        </div>
                        <small class="text-muted">от @total отзива</small>
                    </div>
                    <div class="col-md-9 ps-4">
                        @{
                            var bars = new[]
                            {
                                (5, (int)ViewBag.FiveStars),
                                (4, (int)ViewBag.FourStars),
                                (3, (int)ViewBag.ThreeStars),
                                (2, Model.Where(r => r.Rating == 2).Count()),
                                (1, Model.Where(r => r.Rating == 1).Count())
                            };
                        }
                        @foreach (var (stars, count) in bars)
                        {
                            var pct = total > 0 ? (count * 100 / total) : 0;
                            <div class="d-flex align-items-center mb-1">
                                <span class="me-2 text-muted" style="width:20px">@stars</span>
                                <i class="fas fa-star text-warning me-2 small"></i>
                                <div class="progress flex-grow-1 me-2" style="height:10px">
                                    <div class="progress-bar bg-warning" style="width:@pct%"></div>
                                </div>
                                <span class="text-muted small" style="width:30px">@count</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @* Форма за търсене и филтриране *@
    <div class="card shadow-sm mb-4">
        <div class="card-body py-2">
            <form asp-action="Index" method="get" class="row g-2 align-items-end">
                <div class="col-md-6">
                    <input type="text" name="Search" value="@filter.Search"
                           class="form-control" placeholder="Търси по автор или съдържание..." />
                </div>
                <div class="col-md-3">
                    <select name="MinRating" class="form-select">
                        <option value="">Всички оценки</option>
                        @for (int i = 5; i >= 1; i--)
                        {
                            <option value="@i" selected="@(filter.MinRating == i)">
                                @i+ звезди
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-fill">
                        <i class="fas fa-search me-1"></i>Търси
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fas fa-times"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>

    @* Резултати *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <small class="text-muted">
            Показани <strong>@Model.Count</strong> от <strong>@Model.TotalCount</strong> отзива
        </small>
        <small class="text-muted">Страница @Model.PageIndex от @Model.TotalPages</small>
    </div>

    @* Карти с отзиви *@
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-comment-slash fa-4x text-muted mb-3 d-block"></i>
            <h5 class="text-muted">Няма намерени отзиви.</h5>
            <a asp-action="Index" class="btn btn-outline-primary mt-2">
                <i class="fas fa-times me-1"></i>Изчисти филтрите
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var review in Model)
            {
                <div class="col-md-6">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body p-4">
                            <div class="mb-2">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="fas fa-star @(i <= review.Rating ? "text-warning" : "text-muted") fa-sm"></i>
                                }
                                <span class="ms-1 text-muted small">(@review.Rating/5)</span>
                            </div>
                            <p class="card-text fst-italic text-dark mb-3">
                                "@(review.Content.Length > 200 ? review.Content[..200] + "…" : review.Content)"
                            </p>
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fw-semibold">
                                        <i class="fas fa-user-circle text-primary me-1"></i>@review.AuthorName
                                    </div>
                                    @if (review.Service != null)
                                    {
                                        <small class="text-muted">
                                            <i class="fas fa-tools me-1"></i>@review.Service.Name
                                        </small>
                                    }
                                </div>
                                <div class="text-end">
                                    <small class="text-muted">@review.CreatedDate.ToString("dd.MM.yyyy")</small>
                                    <br />
                                    <a asp-action="Details" asp-route-id="@review.Id"
                                       class="small text-primary">Прочети повече</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @* Pagination *@
        @if (Model.TotalPages > 1)
        {
            <nav class="mt-5 d-flex justify-content-center" aria-label="Pagination">
                <ul class="pagination">
                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@(Model.PageIndex - 1)"
                           asp-route-search="@filter.Search"
                           asp-route-minRating="@filter.MinRating">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-page="@i"
                               asp-route-search="@filter.Search"
                               asp-route-minRating="@filter.MinRating">@i</a>
                        </li>
                    }
                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@(Model.PageIndex + 1)"
                           asp-route-search="@filter.Search"
                           asp-route-minRating="@filter.MinRating">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>
