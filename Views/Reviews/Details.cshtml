@model CarPaintingStudio.Models.Review
@{
    ViewData["Title"] = "Отзив";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0">
                <div class="card-body p-5">

                    @* Звезди *@
                    <div class="text-center mb-4">
                        <div class="mb-2">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="fas fa-star fa-2x @(i <= Model.Rating ? "text-warning" : "text-muted")"></i>
                            }
                        </div>
                        <span class="badge bg-warning text-dark fs-6">@Model.Rating / 5</span>
                    </div>

                    @* Съдържание *@
                    <blockquote class="blockquote text-center mb-4">
                        <p class="fst-italic fs-5 text-dark">"@Model.Content"</p>
                    </blockquote>

                    <hr />

                    @* Автор *@
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fw-bold fs-5">
                                <i class="fas fa-user-circle text-primary me-2"></i>@Model.AuthorName
                            </div>
                            @if (Model.Service != null)
                            {
                                <div class="text-muted mt-1">
                                    <i class="fas fa-tools me-2"></i>Услуга: <strong>@Model.Service.Name</strong>
                                </div>
                            }
                        </div>
                        <div class="text-end text-muted">
                            <i class="fas fa-calendar-alt me-1"></i>
                            @Model.CreatedDate.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("bg-BG"))
                        </div>
                    </div>

                    <div class="mt-4 text-center">
                        <a asp-action="Index" class="btn btn-outline-primary">
                            <i class="fas fa-arrow-left me-2"></i>Всички отзиви
                        </a>
                        <a asp-action="Create" class="btn btn-primary ms-2">
                            <i class="fas fa-pen me-2"></i>Напиши свой отзив
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
