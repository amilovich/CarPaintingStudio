@model CarPaintingStudio.ViewModels.CreateReviewViewModel
@{
    ViewData["Title"] = "Напиши отзив";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">

            <div class="text-center mb-4">
                <i class="fas fa-star fa-3x text-warning mb-2 d-block"></i>
                <h3 class="fw-bold">Сподели своя опит</h3>
                <p class="text-muted">Твоят отзив ще помогне на другите клиенти и ще ни мотивира да се подобряваме.</p>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="AuthorName" class="form-label fw-semibold"></label>
                                <input asp-for="AuthorName" class="form-control" placeholder="Иван Иванов" />
                                <span asp-validation-for="AuthorName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="AuthorEmail" class="form-label fw-semibold"></label>
                                <input asp-for="AuthorEmail" class="form-control" placeholder="ivan@example.com" />
                                <span asp-validation-for="AuthorEmail" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="ServiceId" class="form-label fw-semibold"></label>
                                <select asp-for="ServiceId" class="form-select">
                                    <option value="">— Изберете услуга (по избор) —</option>
                                    @foreach (var s in Model.AvailableServices)
                                    {
                                        <option value="@s.Id">@s.Name (@s.Price.ToString("F0") лв.)</option>
                                    }
                                </select>
                            </div>

                            @* Рейтинг с интерактивни звезди *@
                            <div class="col-12">
                                <label class="form-label fw-semibold">Оценка <span class="text-danger">*</span></label>
                                <div class="star-rating d-flex gap-2 mb-1" id="starRating">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="fas fa-star fa-2x text-muted star-btn"
                                           data-value="@i"
                                           style="cursor:pointer; transition: color 0.15s;"
                                           title="@i звезди"></i>
                                    }
                                </div>
                                <input type="hidden" asp-for="Rating" id="ratingInput" />
                                <span asp-validation-for="Rating" class="text-danger small"></span>
                                <small class="text-muted" id="ratingLabel">Избери оценка</small>
                            </div>

                            <div class="col-12">
                                <label asp-for="Content" class="form-label fw-semibold"></label>
                                <textarea asp-for="Content" class="form-control" rows="5"
                                          placeholder="Опиши своя опит с нашата услуга..."></textarea>
                                <div class="d-flex justify-content-between">
                                    <span asp-validation-for="Content" class="text-danger small"></span>
                                    <small class="text-muted" id="charCount">0/1000</small>
                                </div>
                            </div>
                        </div>

                        <div class="alert alert-info mt-3 mb-4 small">
                            <i class="fas fa-info-circle me-2"></i>
                            Отзивът ще бъде публикуван след преглед от нашия екип.
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-paper-plane me-2"></i>Изпрати отзив
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-arrow-left me-2"></i>Назад
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        // Интерактивни звезди
        const stars = document.querySelectorAll('.star-btn');
        const ratingInput = document.getElementById('ratingInput');
        const ratingLabel = document.getElementById('ratingLabel');
        const labels = ['', 'Лошо', 'Задоволително', 'Добро', 'Много добро', 'Отлично'];

        function setStars(value) {
            stars.forEach(s => {
                const v = parseInt(s.dataset.value);
                s.classList.toggle('text-warning', v <= value);
                s.classList.toggle('text-muted', v > value);
            });
            ratingInput.value = value;
            ratingLabel.textContent = value > 0 ? labels[value] + ' (' + value + '/5)' : 'Избери оценка';
        }

        stars.forEach(star => {
            star.addEventListener('click', () => setStars(parseInt(star.dataset.value)));
            star.addEventListener('mouseover', () => {
                stars.forEach(s => {
                    s.classList.toggle('text-warning', parseInt(s.dataset.value) <= parseInt(star.dataset.value));
                    s.classList.toggle('text-muted', parseInt(s.dataset.value) > parseInt(star.dataset.value));
                });
            });
            star.addEventListener('mouseout', () => setStars(parseInt(ratingInput.value) || 0));
        });

        // Брояч символи
        const textarea = document.querySelector('textarea[name="Content"]');
        const charCount = document.getElementById('charCount');
        textarea.addEventListener('input', () => {
            charCount.textContent = textarea.value.length + '/1000';
        });

        // Зареди текущата стойност ако има
        const current = parseInt(ratingInput.value);
        if (current > 0) setStars(current);
    </script>
}
