@model IEnumerable<CarPaintingStudio.Models.Appointment>
@{
    ViewData["Title"] = "Записвания";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-md-10">
            <h1>
                <i class="fas fa-calendar-alt"></i> Управление на записванията
            </h1>
            <p class="lead">Преглед и управление на всички записвания за услуги</p>
        </div>
        <div class="col-md-2 text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus"></i> Ново записване
            </a>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-warning shadow-sm">
                <div class="card-body text-center">
                    <div class="bg-warning text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-2" 
                         style="width: 60px; height: 60px;">
                        <i class="fas fa-clock fa-2x"></i>
                    </div>
                    <h3 class="mb-0">@Model.Count(a => a.Status == CarPaintingStudio.Models.AppointmentStatus.Pending)</h3>
                    <p class="text-muted mb-0">Чакащи</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-info shadow-sm">
                <div class="card-body text-center">
                    <div class="bg-info text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-2" 
                         style="width: 60px; height: 60px;">
                        <i class="fas fa-check fa-2x"></i>
                    </div>
                    <h3 class="mb-0">@Model.Count(a => a.Status == CarPaintingStudio.Models.AppointmentStatus.Confirmed)</h3>
                    <p class="text-muted mb-0">Потвърдени</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-primary shadow-sm">
                <div class="card-body text-center">
                    <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-2" 
                         style="width: 60px; height: 60px;">
                        <i class="fas fa-spinner fa-2x"></i>
                    </div>
                    <h3 class="mb-0">@Model.Count(a => a.Status == CarPaintingStudio.Models.AppointmentStatus.InProgress)</h3>
                    <p class="text-muted mb-0">В процес</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-success shadow-sm">
                <div class="card-body text-center">
                    <div class="bg-success text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-2" 
                         style="width: 60px; height: 60px;">
                        <i class="fas fa-check-circle fa-2x"></i>
                    </div>
                    <h3 class="mb-0">@Model.Count(a => a.Status == CarPaintingStudio.Models.AppointmentStatus.Completed)</h3>
                    <p class="text-muted mb-0">Завършени</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter buttons -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-outline-primary active" onclick="filterAppointments('all')">
                    <i class="fas fa-list"></i> Всички
                </button>
                <button type="button" class="btn btn-outline-warning" onclick="filterAppointments('pending')">
                    <i class="fas fa-clock"></i> Чакащи
                </button>
                <button type="button" class="btn btn-outline-info" onclick="filterAppointments('confirmed')">
                    <i class="fas fa-check"></i> Потвърдени
                </button>
                <button type="button" class="btn btn-outline-primary" onclick="filterAppointments('inprogress')">
                    <i class="fas fa-spinner"></i> В процес
                </button>
                <button type="button" class="btn btn-outline-success" onclick="filterAppointments('completed')">
                    <i class="fas fa-check-circle"></i> Завършени
                </button>
                <button type="button" class="btn btn-outline-danger" onclick="filterAppointments('cancelled')">
                    <i class="fas fa-times-circle"></i> Отказани
                </button>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> Все още няма записвания.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th><i class="fas fa-calendar"></i> Дата</th>
                        <th><i class="fas fa-user"></i> Клиент</th>
                        <th><i class="fas fa-phone"></i> Телефон</th>
                        <th><i class="fas fa-car"></i> Автомобил</th>
                        <th><i class="fas fa-tools"></i> Услуга</th>
                        <th><i class="fas fa-info-circle"></i> Статус</th>
                        <th><i class="fas fa-cog"></i> Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var appointment in Model)
                    {
                        string statusClass = appointment.Status switch
                        {
                            CarPaintingStudio.Models.AppointmentStatus.Pending => "pending",
                            CarPaintingStudio.Models.AppointmentStatus.Confirmed => "confirmed",
                            CarPaintingStudio.Models.AppointmentStatus.InProgress => "inprogress",
                            CarPaintingStudio.Models.AppointmentStatus.Completed => "completed",
                            CarPaintingStudio.Models.AppointmentStatus.Cancelled => "cancelled",
                            _ => ""
                        };

                        <tr class="appointment-row" data-status="@statusClass">
                            <td>
                                <strong>@appointment.AppointmentDate.ToString("dd.MM.yyyy")</strong>
                            </td>
                            <td>
                                @appointment.CustomerName
                                <br />
                                <small class="text-muted">
                                    <i class="fas fa-envelope"></i> @appointment.Email
                                </small>
                            </td>
                            <td>
                                <a href="tel:@appointment.Phone">@appointment.Phone</a>
                            </td>
                            <td>
                                <strong>@appointment.CarBrand @appointment.CarModel</strong>
                                @if (appointment.CarYear.HasValue)
                                {
                                    <br />
                                    <small class="text-muted">(@appointment.CarYear)</small>
                                }
                            </td>
                            <td>
                                @appointment.Service?.Name
                                <br />
                                <small class="text-success">
                                    <i class="fas fa-tag"></i> @appointment.Service?.Price лв
                                </small>
                            </td>
                            <td>
                                @switch (appointment.Status)
                                {
                                    case CarPaintingStudio.Models.AppointmentStatus.Pending:
                                        <span class="badge bg-warning">
                                            <i class="fas fa-clock"></i> Чакащ
                                        </span>
                                        break;
                                    case CarPaintingStudio.Models.AppointmentStatus.Confirmed:
                                        <span class="badge bg-info">
                                            <i class="fas fa-check"></i> Потвърден
                                        </span>
                                        break;
                                    case CarPaintingStudio.Models.AppointmentStatus.InProgress:
                                        <span class="badge bg-primary">
                                            <i class="fas fa-spinner"></i> В процес
                                        </span>
                                        break;
                                    case CarPaintingStudio.Models.AppointmentStatus.Completed:
                                        <span class="badge bg-success">
                                            <i class="fas fa-check-circle"></i> Завършен
                                        </span>
                                        break;
                                    case CarPaintingStudio.Models.AppointmentStatus.Cancelled:
                                        <span class="badge bg-danger">
                                            <i class="fas fa-times-circle"></i> Отказан
                                        </span>
                                        break;
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group">
                                    <a asp-action="Details" asp-route-id="@appointment.Id" class="btn btn-info text-white" title="Детайли">
                                        <i class="fas fa-info-circle"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@appointment.Id" class="btn btn-warning" title="Редактирай">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@appointment.Id" class="btn btn-danger" title="Изтрий">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>


    }
</div>

@section Scripts {
    <script>
        function filterAppointments(status) {
            const rows = document.querySelectorAll('.appointment-row');
            const buttons = document.querySelectorAll('.btn-group .btn');
            
            // Remove active class from all buttons
            buttons.forEach(btn => btn.classList.remove('active'));
            
            // Add active class to clicked button
            event.target.closest('button').classList.add('active');
            
            if (status === 'all') {
                rows.forEach(row => row.style.display = '');
            } else {
                rows.forEach(row => {
                    if (row.dataset.status === status) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });
            }
        }
    </script>
}
