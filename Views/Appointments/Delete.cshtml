@model CarPaintingStudio.Models.Appointment
@using CarPaintingStudio.Models
@{
    ViewData["Title"] = "Изтриване на записване";

    var statusLabel = Model.Status switch
    {
        AppointmentStatus.Pending    => "Чакащ",
        AppointmentStatus.Confirmed  => "Потвърден",
        AppointmentStatus.InProgress => "В процес",
        AppointmentStatus.Completed  => "Завършен",
        AppointmentStatus.Cancelled  => "Отказан",
        _ => "Неизвестен"
    };
    var statusClass = Model.Status switch
    {
        AppointmentStatus.Pending    => "bg-warning text-dark",
        AppointmentStatus.Confirmed  => "bg-info text-dark",
        AppointmentStatus.InProgress => "bg-primary",
        AppointmentStatus.Completed  => "bg-success",
        AppointmentStatus.Cancelled  => "bg-danger",
        _ => "bg-secondary"
    };
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">

            <div class="text-center mb-4">
                <i class="fas fa-trash-alt fa-3x text-danger mb-3 d-block"></i>
                <h3 class="fw-bold text-danger">Изтриване на записване</h3>
                <p class="text-muted">Тази операция е необратима и не може да бъде отменена</p>
            </div>

            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger bg-opacity-10 border-danger">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fas fa-exclamation-triangle text-danger"></i>
                        <strong class="text-danger">Сигурни ли сте?</strong>
                        <span class="text-muted small ms-1">
                            Записване на <strong>@Model.CustomerName</strong>
                        </span>
                    </div>
                </div>
                <div class="card-body p-4">

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="bg-light rounded p-3">
                                <div class="text-muted small mb-1">Клиент</div>
                                <div class="fw-semibold">@Model.CustomerName</div>
                                <small class="text-muted">@Model.Phone</small>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="bg-light rounded p-3">
                                <div class="text-muted small mb-1">Автомобил</div>
                                <div class="fw-semibold">@Model.CarBrand @Model.CarModel</div>
                                @if (Model.CarYear.HasValue)
                                {
                                    <small class="text-muted">@Model.CarYear г.</small>
                                }
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="bg-light rounded p-3">
                                <div class="text-muted small mb-1">Услуга</div>
                                <div class="fw-semibold">@Model.Service?.Name</div>
                                <small class="text-success">@Model.Service?.Price.ToString("F0") лв.</small>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="bg-light rounded p-3">
                                <div class="text-muted small mb-1">Дата и статус</div>
                                <div class="fw-semibold">@Model.AppointmentDate.ToString("dd.MM.yyyy")</div>
                                <span class="badge @statusClass">@statusLabel</span>
                            </div>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger btn-lg flex-fill">
                                <i class="fas fa-trash me-2"></i>Да, изтрий
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg flex-fill">
                                <i class="fas fa-times me-2"></i>Отказ
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
