@model IEnumerable<CarPaintingStudio.Models.GalleryItem>
@{
    ViewData["Title"] = "Галерия";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-md-12 text-center">
            <h1>
                <i class="fas fa-images"></i> Нашите проекти
            </h1>
            <p class="lead">Вижте трансформацията на автомобилите, които сме боядисали</p>
        </div>
    </div>

    <!-- View Options -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <h5 class="mb-0">
                                <i class="fas fa-sliders-h"></i> Опции за изглед
                            </h5>
                        </div>
                        <div class="col-md-6 text-end">
                            <div class="btn-group" role="group">
                                <button type="button" class="btn btn-outline-primary active" onclick="setGridView(3)" title="3 колони">
                                    <i class="fas fa-th"></i>
                                </button>
                                <button type="button" class="btn btn-outline-primary" onclick="setGridView(4)" title="4 колони">
                                    <i class="fas fa-th-large"></i>
                                </button>
                                <button type="button" class="btn btn-outline-primary" onclick="setGridView(2)" title="2 колони">
                                    <i class="fas fa-grip-vertical"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            <i class="fas fa-info-circle"></i> Галерията все още е празна. Скоро ще добавим нашите проекти.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="gallery-item col-md-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrEmpty(item.AfterImageUrl))
                        {
                            <img src="@item.AfterImageUrl" class="card-img-top gallery-img" alt="@item.Title">
                        }
                        else
                        {
                            <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 200px;">
                                <i class="fas fa-image fa-3x text-white"></i>
                            </div>
                        }
                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="fas fa-award text-warning"></i> @item.Title
                            </h5>
                            <p class="card-text">@item.Description</p>
                            <hr>
                            <p class="mb-2">
                                <i class="fas fa-car text-primary"></i>
                                <strong>Автомобил:</strong> @item.CarBrand @item.CarModel
                            </p>
                            <p class="mb-2">
                                <i class="fas fa-calendar-check text-success"></i>
                                <strong>Завършен:</strong> @item.CompletedDate.ToString("dd.MM.yyyy")
                            </p>
                        </div>
                        <div class="card-footer bg-white">
                            @if (!string.IsNullOrEmpty(item.BeforeImageUrl) && !string.IsNullOrEmpty(item.AfterImageUrl))
                            {
                                <button class="btn btn-sm btn-outline-primary w-100" 
                                        data-bs-toggle="modal" 
                                        data-bs-target="#modal-@item.Id">
                                    <i class="fas fa-eye"></i> Преди/След
                                </button>
                            }
                        </div>
                    </div>
                </div>

                <!-- Modal for Before/After comparison -->
                @if (!string.IsNullOrEmpty(item.BeforeImageUrl) && !string.IsNullOrEmpty(item.AfterImageUrl))
                {
                    <div class="modal fade" id="modal-@item.Id" tabindex="-1" aria-labelledby="modalLabel-@item.Id" aria-hidden="true">
                        <div class="modal-dialog modal-lg">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title" id="modalLabel-@item.Id">
                                        <i class="fas fa-images"></i> @item.Title - Преди и След
                                    </h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="row">
                                        <div class="col-md-6 text-center">
                                            <h6 class="text-danger">
                                                <i class="fas fa-arrow-left"></i> Преди
                                            </h6>
                                            <img src="@item.BeforeImageUrl" class="img-fluid rounded" alt="Преди">
                                        </div>
                                        <div class="col-md-6 text-center">
                                            <h6 class="text-success">
                                                След <i class="fas fa-arrow-right"></i>
                                            </h6>
                                            <img src="@item.AfterImageUrl" class="img-fluid rounded" alt="След">
                                        </div>
                                    </div>
                                    <hr>
                                    <div class="text-center">
                                        <p><strong>Описание:</strong> @item.Description</p>
                                        <p>
                                            <i class="fas fa-car"></i> <strong>Автомобил:</strong> @item.CarBrand @item.CarModel
                                        </p>
                                        <p>
                                            <i class="fas fa-calendar"></i> <strong>Дата:</strong> @item.CompletedDate.ToString("dd MMMM yyyy")
                                        </p>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                        <i class="fas fa-times"></i> Затвори
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    }

    <!-- Call to action -->
    <div class="row mt-5">
        <div class="col-md-12">
            <div class="card bg-primary text-white shadow">
                <div class="card-body text-center py-5">
                    <h3>
                        <i class="fas fa-paint-roller"></i> Искате ли вашият автомобил да изглежда така?
                    </h3>
                    <p class="lead">Запишете час сега и се уверете в качеството на нашата работа!</p>
                    <a asp-controller="Appointments" asp-action="Create" class="btn btn-light btn-lg">
                        <i class="fas fa-calendar-plus"></i> Запази час
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Add animation to cards on scroll
        document.addEventListener('DOMContentLoaded', function() {
            const cards = document.querySelectorAll('.card');
            
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('fade-in');
                    }
                });
            });

            cards.forEach(card => {
                observer.observe(card);
            });
        });

        // Grid view switcher
        function setGridView(columns) {
            const galleryItems = document.querySelectorAll('.gallery-item');
            const buttons = document.querySelectorAll('.btn-group .btn');
            
            // Remove active class from all buttons
            buttons.forEach(btn => btn.classList.remove('active'));
            
            // Add active class to clicked button
            event.target.closest('button').classList.add('active');
            
            // Update grid classes
            let colClass = '';
            switch(columns) {
                case 2:
                    colClass = 'col-md-6';
                    break;
                case 3:
                    colClass = 'col-md-4';
                    break;
                case 4:
                    colClass = 'col-md-3';
                    break;
                default:
                    colClass = 'col-md-4';
            }
            
            galleryItems.forEach(item => {
                item.className = 'gallery-item mb-4 ' + colClass;
            });
        }
    </script>
}
