@model IEnumerable<CarPaintingStudio.Models.GalleryItem>
@{
    ViewData["Title"] = "Галерия";
}

<div class="container mt-4">

    @* Заглавие *@
    <div class="text-center mb-5">
        <h2 class="fw-bold"><i class="fas fa-images text-primary me-2"></i>Нашите проекти</h2>
        <p class="lead text-muted">Вижте трансформацията на автомобилите, с които работихме</p>
        @if (Model.Any())
        {
            <span class="badge bg-primary px-3 py-2">@Model.Count() завършени проекта</span>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-image fa-4x text-muted mb-3 d-block"></i>
            <h5 class="text-muted">Галерията все още е празна.</h5>
            <p class="text-muted">Скоро ще добавим нашите проекти.</p>
        </div>
    }
    else
    {
        @* Контроли за изглед *@
        <div class="d-flex justify-content-between align-items-center mb-4">
            <small class="text-muted">
                Показани <strong>@Model.Count()</strong> проекта
            </small>
            <div class="btn-group btn-group-sm" role="group" aria-label="Изглед">
                <button type="button" class="btn btn-outline-secondary" onclick="setGrid(2)" title="2 колони">
                    <i class="fas fa-grip-vertical"></i>
                </button>
                <button type="button" class="btn btn-outline-secondary active" onclick="setGrid(3)" title="3 колони">
                    <i class="fas fa-th"></i>
                </button>
                <button type="button" class="btn btn-outline-secondary" onclick="setGrid(4)" title="4 колони">
                    <i class="fas fa-th-large"></i>
                </button>
            </div>
        </div>

        @* Галерия *@
        <div class="row g-4" id="galleryGrid">
            @foreach (var item in Model)
            {
                <div class="col-md-4 gallery-item">
                    <div class="card h-100 shadow-sm border-0">
                        @* Снимка *@
                        <div class="position-relative overflow-hidden" style="height: 220px;">
                            @if (!string.IsNullOrEmpty(item.AfterImageUrl))
                            {
                                <img src="@item.AfterImageUrl" alt="@item.Title"
                                     class="w-100 h-100 object-fit-cover gallery-img"
                                     style="object-fit: cover; transition: transform 0.3s;" />
                            }
                            else
                            {
                                <div class="w-100 h-100 bg-secondary d-flex align-items-center
                                            justify-content-center">
                                    <i class="fas fa-car fa-3x text-white opacity-50"></i>
                                </div>
                            }
                            @* Overlay badge *@
                            <div class="position-absolute top-0 end-0 m-2">
                                <span class="badge bg-dark bg-opacity-75">
                                    <i class="fas fa-calendar me-1"></i>@item.CompletedDate.ToString("MM.yyyy")
                                </span>
                            </div>
                        </div>

                        <div class="card-body">
                            <h5 class="fw-bold mb-1">
                                <i class="fas fa-award text-warning me-1"></i>@item.Title
                            </h5>
                            <p class="text-muted small mb-2">
                                <i class="fas fa-car text-primary me-1"></i>
                                @item.CarBrand @item.CarModel
                            </p>
                            @if (!string.IsNullOrEmpty(item.Description))
                            {
                                <p class="small text-muted mb-0">
                                    @(item.Description.Length > 80 ? item.Description[..80] + "…" : item.Description)
                                </p>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(item.BeforeImageUrl) && !string.IsNullOrEmpty(item.AfterImageUrl))
                        {
                            <div class="card-footer bg-white border-top-0 pt-0">
                                <button class="btn btn-outline-primary btn-sm w-100"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modal-@item.Id">
                                    <i class="fas fa-exchange-alt me-1"></i>Преди / След
                                </button>
                            </div>
                        }
                    </div>
                </div>

                @* Modal Преди/След *@
                @if (!string.IsNullOrEmpty(item.BeforeImageUrl) && !string.IsNullOrEmpty(item.AfterImageUrl))
                {
                    <div class="modal fade" id="modal-@item.Id" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-lg modal-dialog-centered">
                            <div class="modal-content border-0 shadow-lg">
                                <div class="modal-header bg-dark text-white">
                                    <h5 class="modal-title">
                                        <i class="fas fa-images me-2"></i>@item.Title
                                    </h5>
                                    <button type="button" class="btn-close btn-close-white"
                                            data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body p-4">
                                    <div class="row g-3">
                                        <div class="col-md-6 text-center">
                                            <div class="badge bg-danger mb-2 px-3 py-2">
                                                <i class="fas fa-times me-1"></i>Преди
                                            </div>
                                            <img src="@item.BeforeImageUrl" class="img-fluid rounded shadow-sm"
                                                 alt="Преди" />
                                        </div>
                                        <div class="col-md-6 text-center">
                                            <div class="badge bg-success mb-2 px-3 py-2">
                                                <i class="fas fa-check me-1"></i>След
                                            </div>
                                            <img src="@item.AfterImageUrl" class="img-fluid rounded shadow-sm"
                                                 alt="След" />
                                        </div>
                                    </div>
                                    <hr />
                                    <div class="text-center text-muted small">
                                        <i class="fas fa-car me-1"></i>@item.CarBrand @item.CarModel
                                        &nbsp;|&nbsp;
                                        <i class="fas fa-calendar me-1"></i>@item.CompletedDate.ToString("dd.MM.yyyy")
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <a asp-controller="Appointments" asp-action="Create"
                                       class="btn btn-primary btn-sm">
                                        <i class="fas fa-calendar-plus me-1"></i>Запиши час
                                    </a>
                                    <button type="button" class="btn btn-secondary btn-sm"
                                            data-bs-dismiss="modal">Затвори</button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    }

    @* CTA *@
    <div class="card bg-dark text-white shadow-lg mt-5">
        <div class="card-body text-center py-5">
            <h4 class="fw-bold mb-3">
                <i class="fas fa-paint-roller text-warning me-2"></i>
                Искате вашият автомобил да изглежда така?
            </h4>
            <p class="lead mb-4 opacity-75">Запишете час и се уверете в качеството на нашата работа!</p>
            <a asp-controller="Appointments" asp-action="Create" class="btn btn-warning btn-lg px-5">
                <i class="fas fa-calendar-plus me-2"></i>Запиши час сега
            </a>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        // Grid view switcher
        function setGrid(cols) {
            const items   = document.querySelectorAll('.gallery-item');
            const buttons = document.querySelectorAll('.btn-group .btn');

            buttons.forEach(b => b.classList.remove('active'));
            event.currentTarget.classList.add('active');

            const colClass = cols === 2 ? 'col-md-6' : cols === 4 ? 'col-md-3' : 'col-md-4';
            items.forEach(item => {
                item.className = 'gallery-item ' + colClass;
            });
        }

        // Hover zoom ефект
        document.querySelectorAll('.gallery-img').forEach(img => {
            img.closest('.card').addEventListener('mouseenter', () => {
                img.style.transform = 'scale(1.05)';
            });
            img.closest('.card').addEventListener('mouseleave', () => {
                img.style.transform = 'scale(1)';
            });
        });
    </script>
}
