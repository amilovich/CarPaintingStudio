@model CarPaintingStudio.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Вход";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">

            @* Лого/заглавие *@
            <div class="text-center mb-4">
                <i class="fas fa-paint-roller fa-3x text-warning mb-3 d-block"></i>
                <h3 class="fw-bold">Добре дошли!</h3>
                <p class="text-muted">Влезте в своя акаунт в CarPainting Studio</p>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <form asp-action="Login" method="post">
                        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger small" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold">
                                <i class="fas fa-envelope text-muted me-1"></i>Имейл
                            </label>
                            <input asp-for="Email" class="form-control form-control-lg"
                                   placeholder="example@email.com" autocomplete="email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <label asp-for="Password" class="form-label fw-semibold mb-0">
                                    <i class="fas fa-lock text-muted me-1"></i>Парола
                                </label>
                            </div>
                            <div class="input-group">
                                <input asp-for="Password" class="form-control form-control-lg"
                                       placeholder="Вашата парола" id="passwordInput"
                                       autocomplete="current-password" />
                                <button class="btn btn-outline-secondary" type="button"
                                        id="togglePassword" tabindex="-1">
                                    <i class="fas fa-eye" id="toggleIcon"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-4 form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label text-muted small">
                                Запомни ме на този компютър
                            </label>
                        </div>

                        <div class="d-grid mb-3">
                            <button type="submit" class="btn btn-dark btn-lg fw-semibold">
                                <i class="fas fa-sign-in-alt me-2"></i>Вход
                            </button>
                        </div>
                    </form>

                    <hr class="my-3" />

                    <p class="text-center mb-0 small">
                        Нямате акаунт?
                        <a asp-action="Register" class="fw-semibold text-primary">Регистрирайте се безплатно</a>
                    </p>
                </div>
            </div>

            @* Тест акаунти (само за демо) *@
            <div class="card border-0 bg-light mt-3">
                <div class="card-body py-2 px-3">
                    <small class="text-muted d-block mb-1">
                        <i class="fas fa-info-circle me-1"></i>Тестови акаунти:
                    </small>
                    <small class="text-muted">
                        <strong>Admin:</strong> admin@carpaint.bg / Admin123!
                    </small>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        // Показване/скриване на паролата
        document.getElementById('togglePassword').addEventListener('click', function () {
            const input = document.getElementById('passwordInput');
            const icon  = document.getElementById('toggleIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        });
    </script>
}
