@{
    ViewData["Title"] = "Начало";
    var reviews = ViewBag.Reviews as IEnumerable<CarPaintingStudio.Models.Review>
                  ?? new List<CarPaintingStudio.Models.Review>();
}

@* Hero Section *@
<div class="text-white text-center py-5 mb-5 rounded-3"
     style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);">
    <div class="py-4">
        <i class="fas fa-paint-roller fa-3x mb-3 text-warning d-block"></i>
        <h1 class="display-4 fw-bold mb-3" style="color:#fff!important">CarPainting Studio</h1>
        <p class="lead mb-2" style="color:rgba(255,255,255,0.9)!important">
            Вашият партньор за професионално боядисване на автомобили
        </p>
        <p class="mb-4" style="color:rgba(255,255,255,0.7)!important">
            Над 15 години опит | Хиляди доволни клиенти
        </p>

        @* Статистики *@
        <div class="row justify-content-center mb-4">
            <div class="col-auto px-4 border-end" style="border-color:rgba(255,255,255,0.3)!important">
                <div class="fs-3 fw-bold text-warning">@ViewBag.CompletedJobs+</div>
                <small style="color:rgba(255,255,255,0.75)">Завършени проекта</small>
            </div>
            <div class="col-auto px-4 border-end" style="border-color:rgba(255,255,255,0.3)!important">
                <div class="fs-3 fw-bold text-warning">@ViewBag.AvgRating &#x2605;</div>
                <small style="color:rgba(255,255,255,0.75)">Средна оценка</small>
            </div>
            <div class="col-auto px-4">
                <div class="fs-3 fw-bold text-warning">15+</div>
                <small style="color:rgba(255,255,255,0.75)">Години опит</small>
            </div>
        </div>

        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a class="btn btn-warning btn-lg px-4 fw-semibold" asp-controller="Appointments" asp-action="Create">
                <i class="fas fa-calendar-plus me-2"></i>Запиши час сега
            </a>
            <a class="btn btn-outline-light btn-lg px-4" asp-controller="Services" asp-action="Index">
                <i class="fas fa-tools me-2"></i>Нашите услуги
            </a>
        </div>
    </div>
</div>

@* Услуги *@
<div class="row mb-5">
    <div class="col-12 mb-4 text-center">
        <h2 class="fw-bold"><i class="fas fa-tools text-primary me-2"></i>Нашите услуги</h2>
        <p class="text-muted">Открийте пълната гама от професионални услуги</p>
    </div>

    @if (ViewBag.Services != null)
    {
        foreach (var service in ViewBag.Services)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body p-4">
                        <div class="bg-primary bg-opacity-10 rounded p-3 d-inline-block mb-3">
                            <i class="fas fa-paint-roller text-primary fa-lg"></i>
                        </div>
                        <h5 class="fw-bold mb-2">@service.Name</h5>
                        <p class="text-muted small mb-3">
                            @(((string)service.Description).Length > 80
                                ? ((string)service.Description).Substring(0, 80) + "…"
                                : (string)service.Description)
                        </p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-bold text-success fs-5">@service.Price.ToString("F0") лв.</span>
                            <a asp-controller="Services" asp-action="Details" asp-route-id="@service.Id"
                               class="btn btn-outline-primary btn-sm">
                                Детайли <i class="fas fa-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }

    <div class="col-12 text-center mt-2">
        <a class="btn btn-primary btn-lg" asp-controller="Services" asp-action="Index">
            <i class="fas fa-list me-2"></i>Всички услуги
        </a>
    </div>
</div>

@* Галерия preview *@
@if (ViewBag.GalleryItems != null && ViewBag.GalleryItems.Count > 0)
{
    <div class="row mb-5">
        <div class="col-12 mb-4 text-center">
            <h2 class="fw-bold"><i class="fas fa-images text-primary me-2"></i>Нашите проекти</h2>
            <p class="text-muted">Вижте реални резултати от нашата работа</p>
        </div>

        @foreach (var item in ViewBag.GalleryItems)
        {
            <div class="col-md-6 col-lg-3 mb-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body p-3 text-center">
                        <div class="bg-dark bg-opacity-10 rounded p-3 mb-3">
                            <i class="fas fa-car fa-2x text-muted"></i>
                        </div>
                        <h6 class="fw-bold mb-1">@item.Title</h6>
                        <p class="small text-muted mb-0">@item.CarBrand @item.CarModel</p>
                    </div>
                </div>
            </div>
        }

        <div class="col-12 text-center mt-2">
            <a class="btn btn-outline-primary btn-lg" asp-controller="Gallery" asp-action="Index">
                <i class="fas fa-images me-2"></i>Цялата галерия
            </a>
        </div>
    </div>
}

@* Реални отзиви *@
<div class="row mb-5">
    <div class="col-12 mb-4 text-center">
        <h2 class="fw-bold"><i class="fas fa-star text-warning me-2"></i>Казали са за нас</h2>
        <p class="text-muted">Реални отзиви от наши доволни клиенти</p>
    </div>

    @if (reviews.Any())
    {
        foreach (var review in reviews)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body p-4">
                        <div class="mb-3">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="fas fa-star @(i <= review.Rating ? "text-warning" : "text-muted") fa-sm"></i>
                            }
                        </div>
                        <p class="fst-italic text-muted mb-3">
                            "@(review.Content.Length > 120 ? review.Content.Substring(0, 120) + "…" : review.Content)"
                        </p>
                        <div class="d-flex align-items-center">
                            <div class="bg-primary text-white rounded-circle d-flex align-items-center
                                        justify-content-center me-3" style="width:42px;height:42px">
                                <i class="fas fa-user"></i>
                            </div>
                            <div>
                                <div class="fw-semibold">@review.AuthorName</div>
                                @if (review.Service != null)
                                {
                                    <small class="text-muted">@review.Service.Name</small>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center text-muted py-3">
            <i class="fas fa-star fa-2x mb-2 d-block text-warning"></i>
            <p>Все още няма одобрени отзиви. <a asp-controller="Reviews" asp-action="Create">Бъди първият!</a></p>
        </div>
    }

    <div class="col-12 text-center mt-2">
        <a class="btn btn-outline-warning btn-lg" asp-controller="Reviews" asp-action="Index">
            <i class="fas fa-star me-2"></i>Всички отзиви
        </a>
    </div>
</div>

@* Защо да ни изберете *@
<div class="row mb-5">
    <div class="col-12 mb-4 text-center">
        <h2 class="fw-bold"><i class="fas fa-award text-primary me-2"></i>Защо да ни изберете?</h2>
    </div>
    <div class="col-md-6 col-lg-3 mb-4">
        <div class="card border-0 text-center h-100 shadow-sm">
            <div class="card-body p-4">
                <i class="fas fa-medal fa-3x text-primary mb-3"></i>
                <h5 class="fw-bold">15+ години опит</h5>
                <p class="text-muted small mb-0">Дългогодишен опит в автомобилното боядисване</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3 mb-4">
        <div class="card border-0 text-center h-100 shadow-sm">
            <div class="card-body p-4">
                <i class="fas fa-paint-brush fa-3x text-success mb-3"></i>
                <h5 class="fw-bold">Качествени материали</h5>
                <p class="text-muted small mb-0">Използваме само най-добрите бои и лакове</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3 mb-4">
        <div class="card border-0 text-center h-100 shadow-sm">
            <div class="card-body p-4">
                <i class="fas fa-user-check fa-3x text-info mb-3"></i>
                <h5 class="fw-bold">Професионален екип</h5>
                <p class="text-muted small mb-0">Опитни майстори с внимание към детайлите</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3 mb-4">
        <div class="card border-0 text-center h-100 shadow-sm">
            <div class="card-body p-4">
                <i class="fas fa-shield-alt fa-3x text-warning mb-3"></i>
                <h5 class="fw-bold">Гаранция</h5>
                <p class="text-muted small mb-0">Гарантираме качеството на всяка услуга</p>
            </div>
        </div>
    </div>
</div>

@* CTA *@
<div class="card bg-dark text-white shadow-lg mb-4">
    <div class="card-body text-center py-5">
        <h3 class="fw-bold mb-3">
            <i class="fas fa-phone me-2 text-warning"></i>Свържете се с нас днес!
        </h3>
        <p class="lead mb-4">
            <a href="tel:0888123456" class="text-warning text-decoration-none">0888 123 456</a>
            &nbsp;|&nbsp;
            <a href="mailto:info@carpaint.bg" class="text-white text-decoration-none">info@carpaint.bg</a>
        </p>
        <a class="btn btn-warning btn-lg px-5" asp-controller="Appointments" asp-action="Create">
            <i class="fas fa-calendar-check me-2"></i>Запази час
        </a>
    </div>
</div>
