@model CarPaintingStudio.Models.Service
@{
    ViewData["Title"] = Model.Name;
    var reviews = Model.Reviews?.ToList() ?? new List<CarPaintingStudio.Models.Review>();
    var avgRating = reviews.Any() ? Math.Round(reviews.Average(r => r.Rating), 1) : 0;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            @* Заглавна карта *@
            <div class="card shadow-lg mb-4">
                <div class="card-header bg-primary text-white py-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <h2 class="mb-0">
                            <i class="fas fa-paint-roller me-2"></i>@Model.Name
                        </h2>
                        @if (reviews.Any())
                        {
                            <div class="text-end">
                                <div class="fs-4 fw-bold">@avgRating ⭐</div>
                                <small>@reviews.Count отзива</small>
                            </div>
                        }
                    </div>
                </div>
                <div class="card-body p-4">
                    <div class="mb-4 pb-3 border-bottom">
                        <h5 class="text-muted mb-3">
                            <i class="fas fa-align-left me-2"></i>Описание
                        </h5>
                        <p class="lead text-dark">@Model.Description</p>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6 mb-3">
                            <div class="p-4 bg-light rounded border text-center">
                                <h6 class="text-muted text-uppercase mb-2">
                                    <i class="fas fa-tag me-1"></i>Цена
                                </h6>
                                <h2 class="text-success fw-bold mb-0">
                                    @Model.Price.ToString("F0") лв.
                                </h2>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="p-4 bg-light rounded border text-center">
                                <h6 class="text-muted text-uppercase mb-2">
                                    <i class="fas fa-clock me-1"></i>Продължителност
                                </h6>
                                <h2 class="text-primary fw-bold mb-0">
                                    @Model.DurationDays дни
                                </h2>
                            </div>
                        </div>
                    </div>

                    <div class="d-grid">
                        <a asp-controller="Appointments" asp-action="Create"
                           class="btn btn-primary btn-lg">
                            <i class="fas fa-calendar-plus me-2"></i>Запиши час за тази услуга
                        </a>
                    </div>

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="d-flex gap-2 mt-3">
                            <a asp-area="Admin" asp-controller="Services" asp-action="Edit"
                               asp-route-id="@Model.Id" class="btn btn-outline-warning flex-fill">
                                <i class="fas fa-edit me-1"></i>Редактирай
                            </a>
                            <a asp-area="Admin" asp-controller="Services" asp-action="Delete"
                               asp-route-id="@Model.Id" class="btn btn-outline-danger flex-fill">
                                <i class="fas fa-trash me-1"></i>Изтрий
                            </a>
                        </div>
                    }
                </div>
            </div>

            @* Отзиви за услугата *@
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold">
                        <i class="fas fa-star text-warning me-2"></i>
                        Отзиви за тази услуга
                        @if (reviews.Any())
                        {
                            <span class="badge bg-secondary ms-2">@reviews.Count</span>
                        }
                    </h5>
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <a asp-controller="Reviews" asp-action="Create"
                           class="btn btn-sm btn-outline-primary">
                            <i class="fas fa-pen me-1"></i>Напиши отзив
                        </a>
                    }
                </div>
                <div class="card-body">
                    @if (!reviews.Any())
                    {
                        <div class="text-center text-muted py-4">
                            <i class="fas fa-comment-slash fa-2x mb-3 d-block"></i>
                            <p>Все още няма отзиви за тази услуга.</p>
                            @if (User.Identity != null && User.Identity.IsAuthenticated)
                            {
                                <a asp-controller="Reviews" asp-action="Create"
                                   class="btn btn-primary btn-sm">
                                    Бъди първият!
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="row g-3">
                            @foreach (var review in reviews.OrderByDescending(r => r.CreatedDate).Take(5))
                            {
                                <div class="col-md-6">
                                    <div class="border rounded p-3 h-100">
                                        <div class="mb-2">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="fas fa-star fa-sm @(i <= review.Rating ? "text-warning" : "text-muted")"></i>
                                            }
                                            <span class="text-muted small ms-1">(@review.Rating/5)</span>
                                        </div>
                                        <p class="fst-italic small mb-2">
                                            "@(review.Content.Length > 120 ? review.Content[..120] + "…" : review.Content)"
                                        </p>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <small class="fw-semibold text-primary">
                                                <i class="fas fa-user-circle me-1"></i>@review.AuthorName
                                            </small>
                                            <small class="text-muted">@review.CreatedDate.ToString("dd.MM.yyyy")</small>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        @if (reviews.Count > 5)
                        {
                            <div class="text-center mt-3">
                                <a asp-controller="Reviews" asp-action="Index"
                                   class="btn btn-outline-secondary btn-sm">
                                    Виж всички @reviews.Count отзива
                                    <i class="fas fa-arrow-right ms-1"></i>
                                </a>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="text-center mb-4">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Към всички услуги
                </a>
            </div>

        </div>
    </div>
</div>
