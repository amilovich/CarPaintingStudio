@model CarPaintingStudio.ViewModels.ServiceViewModel
@{
    ViewData["Title"] = "Нова услуга";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">

            <div class="text-center mb-4">
                <i class="fas fa-plus-circle fa-3x text-primary mb-3 d-block"></i>
                <h3 class="fw-bold">Добавяне на нова услуга</h3>
                <p class="text-muted">Попълнете данните за новата услуга на сервиза</p>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold">
                                <i class="fas fa-tag text-muted me-1"></i>Наименование
                            </label>
                            <input asp-for="Name" class="form-control"
                                   placeholder="Напр. Пълно боядисване" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold">
                                <i class="fas fa-align-left text-muted me-1"></i>Описание
                            </label>
                            <textarea asp-for="Description" class="form-control" rows="4"
                                      placeholder="Опишете услугата детайлно..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="Price" class="form-label fw-semibold">
                                    <i class="fas fa-money-bill text-muted me-1"></i>Цена
                                </label>
                                <div class="input-group">
                                    <input asp-for="Price" class="form-control" placeholder="2500" />
                                    <span class="input-group-text fw-semibold text-success">лв.</span>
                                </div>
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="DurationDays" class="form-label fw-semibold">
                                    <i class="fas fa-clock text-muted me-1"></i>Продължителност
                                </label>
                                <div class="input-group">
                                    <input asp-for="DurationDays" class="form-control" placeholder="7" />
                                    <span class="input-group-text">дни</span>
                                </div>
                                <span asp-validation-for="DurationDays" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" role="switch" />
                                <label asp-for="IsActive" class="form-check-label fw-semibold">
                                    Активна услуга
                                </label>
                            </div>
                            <small class="text-muted">Само активните услуги се показват на клиентите</small>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary btn-lg flex-fill">
                                <i class="fas fa-save me-2"></i>Запази услугата
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-times me-1"></i>Отказ
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
