@model ServiceViewModel
@{
    ViewData["Title"] = "Създай услуга";
}

<div class="container">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>
                <i class="fas fa-plus"></i> Създай нова услуга
            </h1>
            <hr />

            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" placeholder="Напр. Пълно боядисване" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Опишете услугата детайлно..."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Price" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="Price" class="form-control" placeholder="2500" />
                            <span class="input-group-text">лв</span>
                        </div>
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="DurationDays" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="DurationDays" class="form-control" placeholder="7" />
                            <span class="input-group-text">дни</span>
                        </div>
                        <span asp-validation-for="DurationDays" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label"></label>
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Създай
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Назад
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
