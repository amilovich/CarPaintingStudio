@model CarPaintingStudio.ViewModels.PaginatedList<CarPaintingStudio.Models.Service>
@{
    ViewData["Title"] = "Услуги";
    var filter = ViewBag.Filter as CarPaintingStudio.ViewModels.ServiceFilterViewModel
                 ?? new CarPaintingStudio.ViewModels.ServiceFilterViewModel();
}

<div class="container mt-4">

    <div class="row align-items-center mb-4">
        <div class="col-md-8">
            <h2 class="fw-bold"><i class="fas fa-tools text-primary me-2"></i>Нашите услуги</h2>
            <p class="text-muted">Открийте цялата гама от професионални услуги за боядисване</p>
        </div>
        <div class="col-md-4 text-md-end">
            @if (User.IsInRole("Admin"))
            {
                <a asp-area="Admin" asp-controller="Services" asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-plus me-1"></i>Нова услуга
                </a>
            }
        </div>
    </div>

    @* Форма за филтриране и търсене *@
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-search me-1"></i>Търсене
                    </label>
                    <input type="text" name="Search" value="@filter.Search"
                           class="form-control" placeholder="Напр. боядисване, полиране..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Мин. цена (лв.)</label>
                    <input type="number" name="MinPrice" value="@filter.MinPrice"
                           class="form-control" placeholder="0" min="0" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Макс. цена (лв.)</label>
                    <input type="number" name="MaxPrice" value="@filter.MaxPrice"
                           class="form-control" placeholder="10000" min="0" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-sort me-1"></i>Сортиране
                    </label>
                    <select name="SortBy" class="form-select">
                        <option value="" selected="@(filter.SortBy == null)">Най-нови</option>
                        <option value="price_asc"     selected="@(filter.SortBy == "price_asc")">Цена ↑</option>
                        <option value="price_desc"    selected="@(filter.SortBy == "price_desc")">Цена ↓</option>
                        <option value="duration_asc"  selected="@(filter.SortBy == "duration_asc")">Срок ↑</option>
                        <option value="duration_desc" selected="@(filter.SortBy == "duration_desc")">Срок ↓</option>
                        <option value="name_asc"      selected="@(filter.SortBy == "name_asc")">Име А-Я</option>
                    </select>
                </div>
                <div class="col-md-1 d-flex gap-1">
                    <button type="submit" class="btn btn-primary w-100" title="Търси">
                        <i class="fas fa-search"></i>
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary" title="Изчисти">
                        <i class="fas fa-times"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>

    @* Резултати *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <small class="text-muted">
            Показани <strong>@Model.Count</strong> от <strong>@Model.TotalCount</strong> услуги
            @if (!string.IsNullOrEmpty(filter.Search))
            {
                <span>за „<em>@filter.Search</em>"</span>
            }
        </small>
        <small class="text-muted">Страница @Model.PageIndex от @Model.TotalPages</small>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-search fa-3x text-muted mb-3 d-block"></i>
            <h5 class="text-muted">Няма намерени услуги по зададените критерии.</h5>
            <a asp-action="Index" class="btn btn-outline-primary mt-2">
                <i class="fas fa-times me-2"></i>Изчисти филтрите
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var service in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="bg-primary bg-opacity-10 rounded p-2">
                                    <i class="fas fa-paint-roller text-primary fa-lg"></i>
                                </div>
                                <span class="badge bg-success">Активна</span>
                            </div>
                            <h5 class="fw-bold mb-2">@service.Name</h5>
                            <p class="text-muted small mb-3">
                                @(service.Description.Length > 100
                                    ? service.Description[..100] + "…"
                                    : service.Description)
                            </p>
                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                <div>
                                    <div class="fw-bold text-success fs-5">
                                        @service.Price.ToString("F0") лв.
                                    </div>
                                    <small class="text-muted">
                                        <i class="fas fa-calendar-day me-1"></i>@service.DurationDays дни
                                    </small>
                                </div>
                                <a asp-action="Details" asp-route-id="@service.Id"
                                   class="btn btn-outline-primary btn-sm">
                                    Детайли <i class="fas fa-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                        @if (User.IsInRole("Admin"))
                        {
                            <div class="card-footer bg-light d-flex gap-1 py-2">
                                <a asp-area="Admin" asp-controller="Services" asp-action="Edit"
                                   asp-route-id="@service.Id" class="btn btn-sm btn-outline-warning flex-fill">
                                    <i class="fas fa-edit me-1"></i>Редактирай
                                </a>
                                <a asp-area="Admin" asp-controller="Services" asp-action="Delete"
                                   asp-route-id="@service.Id" class="btn btn-sm btn-outline-danger">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        @* Pagination *@
        @if (Model.TotalPages > 1)
        {
            <nav class="mt-5 d-flex justify-content-center" aria-label="Pagination">
                <ul class="pagination">
                    @* Предишна *@
                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@(Model.PageIndex - 1)"
                           asp-route-search="@filter.Search"
                           asp-route-minPrice="@filter.MinPrice"
                           asp-route-maxPrice="@filter.MaxPrice"
                           asp-route-sortBy="@filter.SortBy">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    </li>

                    @* Номера *@
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-page="@i"
                               asp-route-search="@filter.Search"
                               asp-route-minPrice="@filter.MinPrice"
                               asp-route-maxPrice="@filter.MaxPrice"
                               asp-route-sortBy="@filter.SortBy">@i</a>
                        </li>
                    }

                    @* Следваща *@
                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@(Model.PageIndex + 1)"
                           asp-route-search="@filter.Search"
                           asp-route-minPrice="@filter.MinPrice"
                           asp-route-maxPrice="@filter.MaxPrice"
                           asp-route-sortBy="@filter.SortBy">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>
