@model IEnumerable<Service>
@{
    ViewData["Title"] = "Услуги";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-md-10">
            <h1>
                <i class="fas fa-tools"></i> Нашите услуги
            </h1>
            <p class="lead">Открийте цялата гама от професионални услуги за боядисване на автомобили</p>
        </div>
        <div class="col-md-2 text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus"></i> Добави услуга
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> Все още няма добавени услуги.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var service in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card h-100 shadow-sm @(service.IsActive ? "" : "border-danger")">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title">
                                    <i class="fas fa-paint-roller text-primary"></i> @service.Name
                                </h5>
                                @if (!service.IsActive)
                                {
                                    <span class="badge bg-danger">Неактивна</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Активна</span>
                                }
                            </div>
                            <p class="card-text">@service.Description</p>
                            <div class="row mt-3">
                                <div class="col-6">
                                    <strong><i class="fas fa-tag"></i> Цена:</strong>
                                    <span class="text-success fw-bold">@service.Price лв</span>
                                </div>
                                <div class="col-6">
                                    <strong><i class="fas fa-clock"></i> Време:</strong>
                                    <span>@service.DurationDays дни</span>
                                </div>
                            </div>
                            <div class="mt-3">
                                <small class="text-muted">
                                    <i class="fas fa-calendar-alt"></i> Добавена: @service.CreatedDate.ToString("dd.MM.yyyy")
                                </small>
                            </div>
                        </div>
                        <div class="card-footer bg-white">
                            <div class="btn-group" role="group">
                                <a asp-action="Details" asp-route-id="@service.Id" class="btn btn-sm btn-info text-white">
                                    <i class="fas fa-info-circle"></i> Детайли
                                </a>
                                <a asp-action="Edit" asp-route-id="@service.Id" class="btn btn-sm btn-warning">
                                    <i class="fas fa-edit"></i> Редактирай
                                </a>
                                <a asp-action="Delete" asp-route-id="@service.Id" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash"></i> Изтрий
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
